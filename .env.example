# ── Telegram ───────────────────────────────────────────────
# Token from @BotFather
TELEGRAM_BOT_TOKEN=

# Secret used to validate the X-Telegram-Bot-Api-Secret-Token webhook header.
# Generate: python -c "import secrets; print(secrets.token_urlsafe(32))"
TELEGRAM_WEBHOOK_SECRET=

# ── Claude / Anthropic ─────────────────────────────────────
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6

# ── Google Sheets ──────────────────────────────────────────
# The user creates their own spreadsheet and adds the service account email as an editor.
# The email comes from the service account JSON key (client_email field).
# Local: path to the file; in Lambda store the secret in SSM/Secrets Manager (see docs/SETUP.md).
GOOGLE_SERVICE_ACCOUNT_FILE=./service-account.json

# ── AWS / DynamoDB ─────────────────────────────────────────
AWS_REGION=eu-central-1
USER_PROFILE_TABLE=calorie_bot_user_profile
USER_STATES_TABLE=calorie_bot_user_states
USER_FOODS_TABLE=calorie_bot_user_foods

# ── Misc ───────────────────────────────────────────────────
LOG_LEVEL=INFO
